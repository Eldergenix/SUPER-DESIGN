{
  "name": "example-linear-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Super Design end-to-end example — a Linear Projects dashboard built from the linear.app DESIGN.md brand extraction, using only tokens generated by the skill's generate-theme.mjs.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "theme:generate": "node ../../skill/skills/super-design/scripts/generate-theme.mjs DESIGN.md --target=tailwind-v4 --out=src/index.css",
    "theme:lint": "bash ../../skill/skills/super-design/scripts/lint-design-md.sh DESIGN.md",
    "theme:contrast": "node ../../skill/skills/super-design/scripts/contrast-check.mjs DESIGN.md",
    "quality:score": "bash ../../skill/skills/super-design/scripts/quality-score.sh src/App.tsx",
    "quality:audit": "bash ../../skill/skills/super-design/scripts/audit.sh src/"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
