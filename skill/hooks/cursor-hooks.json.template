{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "pattern": "**/*.{tsx,jsx,ts,js,vue,svelte,css,scss,astro}",
        "command": "bash .claude/skills/super-design/scripts/validate-tokens.sh \"${file}\""
      },
      {
        "pattern": "**/*.{tsx,jsx,vue,svelte}",
        "command": "bash .claude/skills/super-design/scripts/validate-component.sh \"${file}\""
      }
    ]
  }
}
