{
  "name": "super-design",
  "version": "1.2.0",
  "description": "Production-grade design system skill for Claude Code, Cursor, Codex, Gemini, Copilot, and more. Reads DESIGN.md, sets up theme tokens, enforces UI/UX quality gates, responsive guardrails, reusability rules, 44x44 touch targets, and 300-LOC component limits via PostToolUse hooks. Auto-generates a design system showcase page and maintains a running UI memory log.",
  "bin": {
    "super-design": "./bin/install.js"
  },
  "scripts": {
    "install-skill": "node ./bin/install.js",
    "test": "bash ./skills/super-design/scripts/quality-score.sh README.md || true"
  },
  "files": [
    "skills/",
    "hooks/",
    "bin/",
    ".claude-plugin/",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "claude-skill",
    "design-system",
    "design-tokens",
    "design-md",
    "ui",
    "ux",
    "tailwind",
    "shadcn",
    "mui",
    "radix",
    "geist",
    "cursor",
    "copilot",
    "codex",
    "gemini",
    "antigravity",
    "screenshot-to-code",
    "pixel-perfect",
    "accessibility",
    "wcag",
    "responsive",
    "hooks",
    "quality-gates",
    "visual-regression"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Eldergenix/SUPER-DESIGN"
  },
  "homepage": "https://github.com/Eldergenix/SUPER-DESIGN",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "odiff-bin": "^3.0.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0"
  }
}
