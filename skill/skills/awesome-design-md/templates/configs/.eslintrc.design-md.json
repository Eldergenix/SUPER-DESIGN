{
  "$schema": "https://json.schemastore.org/eslintrc",
  "extends": [
    "eslint:recommended",
    "plugin:react/recommended",
    "plugin:jsx-a11y/recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "plugins": ["react", "jsx-a11y", "sonarjs"],
  "rules": {
    "max-lines":              ["warn", { "max": 300, "skipBlankLines": true, "skipComments": true }],
    "max-lines-per-function": ["warn", { "max": 50,  "skipBlankLines": true, "skipComments": true }],
    "complexity":             ["warn", { "max": 10 }],
    "max-depth":              ["warn", { "max": 4 }],
    "max-params":             ["warn", { "max": 4 }],
    "max-nested-callbacks":   ["warn", { "max": 3 }],
    "no-nested-ternary":      "warn",
    "prefer-const":           "error",

    "react/no-multi-comp":                "error",
    "react/jsx-key":                      "error",
    "react/self-closing-comp":            "warn",
    "react/jsx-no-useless-fragment":      "warn",

    "jsx-a11y/alt-text":                       "error",
    "jsx-a11y/anchor-has-content":             "error",
    "jsx-a11y/anchor-is-valid":                "error",
    "jsx-a11y/aria-props":                     "error",
    "jsx-a11y/aria-role":                      "error",
    "jsx-a11y/aria-unsupported-elements":      "error",
    "jsx-a11y/click-events-have-key-events":   "error",
    "jsx-a11y/no-static-element-interactions": "error",
    "jsx-a11y/label-has-associated-control":   "error",
    "jsx-a11y/no-autofocus":                   "warn",
    "jsx-a11y/interactive-supports-focus":     "error",
    "jsx-a11y/role-has-required-aria-props":   "error",
    "jsx-a11y/tabindex-no-positive":           "error",

    "sonarjs/cognitive-complexity":   ["warn", 15],
    "sonarjs/no-duplicate-string":    ["warn", { "threshold": 3 }],
    "sonarjs/no-identical-functions": "warn",

    "no-restricted-syntax": [
      "error",
      {
        "selector": "JSXAttribute[name.name='style'] ObjectExpression Property[key.name=/color|background|backgroundColor|borderColor|fill|stroke/] Literal[value=/^#|^rgb|^hsl/]",
        "message": "Do not use literal colors in inline styles. Use theme tokens via className."
      }
    ]
  },
  "settings": {
    "react": { "version": "detect" }
  }
}
